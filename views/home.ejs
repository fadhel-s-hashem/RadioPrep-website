<%- include("./partials/nav.ejs") %>



<main class="page-container">

    <!-- Hero Section -->
    <section>
        <% if (user) { %>
        <h1>Welcome <%= user.username %>, to RadioPrep.</h1>
        <p>Your comprehensive medical radiology reference and prep tool.</p>
        <br>
        <form action="auth/sign-out?_method=DELETE" method="post">
      <button type="submit" class="btn btn-primary outHome"> sign out <output></output></button>
      </form>
    <% } else { %>
        <h1>Welcome to RadioPrep</h1>
        <p>Your comprehensive medical radiology reference and prep tool.</p>
       
    <% } %>
    </section>

    <!-- Horizontal Card Section -->
    <article class="card">
      <div class="card-media">
        <img src="/images/RadioPrep.png" alt="RadioPrep" width="225dvh" class="rounded mx-auto d-block imgHome">
      </div>
      <div class="card-body">
        <h2 class="homeCard-title">Diagnostic Radiology Overview</h2>
        <p class="card-text">
          Explore key imaging protocols, anatomy positioning guides, and quick reference material designed to assist technologist prep and study workflows.
        </p>
      </div>
    </article>

  </main>

  <hr>
  
  <br>
<!-- website function Summary ====================================-->
<div class="row g-4 py-2 text-start">
    
    <!-- Patient Card -->
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm p-3 rounded-3 bg-light">
            <div class="card-body">
                <div class="fs-2 mb-2 text-primary">💬</div>
                <h5 class="fw-bold text-dark">Patient Access & Feedback</h5>
                <p class="text-secondary small mb-0">
                    Patients can easily view exam preparation cards and leave comments or questions to ensure they are fully prepared.
                </p>
            </div>
        </div>
    </div>

    <!-- Staff Card -->
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm p-3 rounded-3 bg-light">
            <div class="card-body">
                <div class="fs-2 mb-2 text-primary">⚙️</div>
                <h5 class="fw-bold text-dark">Staff Management</h5>
                <p class="text-secondary small mb-0">
                    Staff can create, update, or delete exam details in real time so everyday radiology workflows run smoothly.
                </p>
            </div>
        </div>
    </div>

</div>
</body>
</html>
