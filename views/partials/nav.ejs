<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RadioPrep</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/style.css">

    <link rel="icon" type="image/svg" href="/images/RadioPrep.svg">
</head>

<body>
    <nav class="site-nav">
       <% if (user) { %>
       <span class="fw-bold text-dark d-flex align-items-center gap-2">

            <!-- Icon before the username -->
            <% if (user.staff) { %>
                <img src="/images/staff.svg" alt="Staff"   class="chatImage" >
                
            <% } else { %>
                <img src="/images/noStaff.svg" alt="User"  title="User" class="chatImage">
            <% } %>
           <p class=" mb-1"><%= user.username %></p>
        </span>
         <% } %>

        <div class="site-nav-links">
            <a class="site-nav-link" href="/">Home</a>

             <% if (user && user.staff) { %>
                <a href="/info/newInfo" class="site-nav-link">Creat card</a>
                    <% } %>

            <% if (user) { %>
                <a class="site-nav-link" href="/info/index"> all Cards</a>

                <form
                    class="site-nav-form"
                    action="/auth/sign-out?_method=DELETE"
                    method="POST"
                >
                    <button class="site-nav-button" type="submit">
                        Sign Out
                    </button>
                </form>
            <% } else { %>
                <a class="site-nav-link" href="/auth/sign-up">Sign Up</a>
                <a class="site-nav-link" href="/auth/sign-in">Sign In</a>
            <% } %>
        </div>
    </nav>
