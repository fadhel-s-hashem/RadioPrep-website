<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<%- include("../partials/nav.ejs") %>
<body>

    <div class="container my-5 newInfo" >
  <div class="card shadow-sm border-0 rounded-3">
    
    <!-- Card Header -->
    <div class="card-header bg-white border-bottom p-4">
      <h2 class="h4 fw-bold mb-0" style="color: #0284C7;">
        Create New Examination Card
      </h2>
    </div>

    <!-- Form Body -->
    <div class="card-body p-4">
      <form action="/info" method="post">

        <!-- Examination name ==================-->
        <div class="mb-3">
          <label for="name" class="form-label fw-semibold text-secondary">Examination Name</label>
          <input 
            type="text" 
            name="name" 
            id="name" 
            class="form-control" 
            required
          >
        </div>

        <!-- duration & Radiology Unit============== -->
        <div class="row g-3 mb-3">
          
          <!-- Expected Duration -->
          <div class="col-md-6">
            <label for="duration" class="form-label fw-semibold text-secondary">Expected Duration (Mins)</label>
            <div class="input-group">
              <span class="input-group-text bg-light">⏱️</span>
              <input 
                type="number" 
                name="duration" 
                id="duration" 
                class="form-control" 
                 
                required
              >
            </div>
          </div>

          <!-- Select Radiology Unit -->
          <div class="col-md-6">
            <label for="radiologyUnit" class="form-label fw-semibold text-secondary">Radiology Unit</label>
            <select name="radiologyUnit" id="radiologyUnit" class="form-select" required>
              <option value="" disabled selected>Select Modality...</option>
              <option value="general-xray">General X-Ray</option>
              <option value="CT">CT Scan</option>
              <option value="MRI">MRI</option>
              <option value="US">Ultrasound (US)</option>
              <option value="fluor">Fluoroscopy (Fluor)</option>
              <option value="BMD">Bone Mineral Density (BMD)</option>
            </select>
          </div>

        </div>

        <!-- Important Notices (Multiple Inputs) -->
        <div class="mb-3">
          <label class="form-label fw-semibold text-secondary">Important Preparation Notices</label>
          <div class="d-flex flex-column gap-2">
            <input type="text" name="notice" class="form-control" >
            <input type="text" name="notice" class="form-control">
            <input type="text" name="notice" class="form-control" >
            <input type="text" name="notice" class="form-control" >
          </div>
          
        </div>

        <!-- General Info ========================= -->
        <div class="mb-4">
          <label for="generalInfo" class="form-label fw-semibold text-secondary">General Overview & Instructions</label>
          <textarea 
            name="generalInfo" 
            id="generalInfo" 
            class="form-control" 
            rows="4" 
            required
          ></textarea>
        </div>

        <!-- Button ========================= -->
        <div class="d-grid">
        <button type="submit" class="btn btn-primary py-2 fs-6 fw-semibold">
        Create Info Card
        </button>
        </div>

      </form>
    </div>

  </div>
</div>
    
</body>
</html>