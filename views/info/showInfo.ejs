<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
</head>
<%- include("../partials/nav.ejs") %>

  <body>


    <div class="card mb-4 border-0 shadow-lg p-3 p-md-4 showCard">
      <div class="row g-4 align-items-center flex-row">

        <!-- LEFT SIDe Image -->
        <div class="col-12 col-md-4 text-center text-md-start p-2">
          <div class="p-3 rounded-3 text-center">
            <img src="/images/<%= foundInfo.radiologyUnit %>.png" class="img-fluid rounded"
              alt="<%= foundInfo.radiologyUnit %> image" style="max-height: 260px; width: 100%; object-fit: contain;">

            </span>
          </div>
        </div>

        <!-- RIGHT SIDE: Detailed Content Column -->
        <div class="col-12 col-md-8">
          <div class="card-body text-start p-1 p-md-2">

            <!-- Title ============= -->
            <h1 class="card-title text-start mb-3 display-6 fw-bold" style="color: #0284C7;">
              <%= foundInfo.name %>
            </h1>

            <!-- ========================================= -->
            <div class="row g-2 mb-3">
              <!-- Radiology Unit Type -->
              <div class="col-sm-6">
                <div class="p-2 rounded" style="background-color: #F0F9FF; border: 1px solid #BAE6FD;">
                  <small class="text-uppercase fw-bold d-block" style="color: #0284C7; font-size: 0.75rem;">
                    Radiology Unit Type
                  </small>
                  <span class="fw-bold text-dark fs-6">
                    🖥️ <%= foundInfo.radiologyUnit %>
                  </span>
                </div>
              </div>

              <!-- Expected Duration ============= -->
              <div class="col-sm-6">
                <div class="p-2 rounded" style="background-color: #F0FDF4; border: 1px solid #BBF7D0;">
                  <small class="text-uppercase fw-bold d-block text-success" style="font-size: 0.75rem;">
                    Expected Duration
                  </small>
                  <span class="fw-bold text-dark fs-6">
                    ⏱️ <%= foundInfo.duration %> Minutes
                  </span>
                </div>
              </div>
            </div>

            <!-- General Info========== -->
            <div class="mb-3">
              <h6 class="fw-bold text-uppercase mb-1">
                General Overview & Instructions:
              </h6>
              <p class="card-text text-secondary fs-6 mb-0" style="line-height: 1.6;">
                <%= foundInfo.generalInfo %>
              </p>
            </div>

            <!-- Important Notices Section -->
              <div class="mt-3 p-3 rounded-3 infoNotice">
                <h6 class="fw-bold text-danger mb-2 fs-6">
                  ⚠️ Important Preparation Notices:
                </h6>
                <ul class="mb-0 ps-3">
                  <% foundInfo.notice.forEach(function(item) { %>
                    <% if (item !=='' ) { %>
                      <li class="text-dark small mb-1">
                        <%= item %>
                      </li>
                      <% } %>
                        <% }) %>
                </ul>
              </div>
           

          </div>
        </div>

      </div>

      <!-- only staff can see these two buttons ===========================-->
      <% if (user && user.staff) { %>
        <div class="d-flex align-items-center gap-2 my-3">

          <!-- Delete_Button -->

          <button type="button" class="btn btn-danger w-auto px-3" data-bs-toggle="modal"
            data-bs-target="#exampleModal">
            Delete this Card
          </button>

          <!-- Modal_Edit Button -->
          <button type="button" class="btn btn-warning w-auto px-3" data-bs-toggle="modal"
            data-bs-target="#staticBackdrop">
            Edit this card
          </button>

        </div>
        <% } %>
    </div>

    <!-- modal Delete ===========================-->
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5" id="exampleModalLabel"> Delete: <%= foundInfo.name%></h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            Are you shoure you want to delete this card
          </div>
          <div class="modal-footer">
            <form action="/info/<%= foundInfo._id %>?_method=DELETE" method="post">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
              <button type="submit" class="btn btn-danger w-auto px-3">Yes, Delete</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal edit==============================-->
    <div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
      aria-labelledby="staticBackdropLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5" id="staticBackdropLabel"> Edit : <%= foundInfo.name%>
            </h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>

          <form action="/info/<%= foundInfo._id%>?_method=PUT" method="post">
            <div class="modal-body">

              <!-- Examination Name -->
              <div class="mb-3">
                <label for="name" class="form-label">Examination Name</label>
                <input type="text" class="form-control" name="name" id="name" value="<%= foundInfo.name%>" required>
              </div>

              <!-- Expected Duration -->
              <div class="mb-3">
                <label for="duration" class="form-label">Expected Duration (mins)</label>
                <input type="number" class="form-control" name="duration" id="duration" value="<%= foundInfo.duration%>"
                  required>
              </div>

              <!-- Radiology Unit -->
              <div class="mb-3">
                <label for="radiologyUnit" class="form-label">Select Radiology Unit</label>
                <select class="form-select" name="radiologyUnit" id="radiologyUnit" required>
                  <option value="<%= foundInfo.radiologyUnit%>" selected>
                    <%= foundInfo.radiologyUnit%>
                  </option>
                  <option value="general-xray">general-xray</option>
                  <option value="CT">CT</option>
                  <option value="MRI">MRI</option>
                  <option value="US">Ultrasound (US)</option>
                  <option value="fluor">Fluoroscopy (fluor)</option>
                  <option value="BMD">Bone Mineral Density (BMD)</option>
                </select>
              </div>

              <!-- Important Notices -->
              <div class="mb-3">
                <label class="form-label">Important Notices</label>
                <input type="text" class="form-control mb-2" name="notice" value="<%= foundInfo.notice[0]%>"
                  placeholder="Notice 1">
                <input type="text" class="form-control mb-2" name="notice" value="<%= foundInfo.notice[1]%>"
                  placeholder="Notice 2">
                <input type="text" class="form-control mb-2" name="notice" value="<%= foundInfo.notice[2]%>"
                  placeholder="Notice 3">
                <input type="text" class="form-control" name="notice" value="<%= foundInfo.notice[3]%>"
                  placeholder="Notice 4">
              </div>

              <!-- General Info -->
              <div class="mb-3">
                <label for="generalInfo" class="form-label">Add General Info</label>
                <textarea class="form-control" name="generalInfo" id="generalInfo" rows="4"
                  required><%= foundInfo.generalInfo %></textarea>
              </div>

            </div>

            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
              <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
          </form>
        </div>


      </div>
    </div>

    <!-- ================================================================================ -->
    <!--comments ====================================================================  -->

    <section class="comments-display-section my-4">
      <h2 class="h4 fw-bold mb-3" style="color: #0284C7;">
        Discussion & Feedback (<%= foundInfo.comments.length %>)
      </h2>

      <% if ( foundInfo.comments.length> 0) { %>
        <div class="d-flex flex-column gap-3">
          <% foundInfo.comments.forEach(function(item) { %>

            <!-- Individual Comment Card -->
            <div class="card border-0 shadow-sm rounded-3 bg-white">
              <div class="card-body p-3">


                <div class="d-flex justify-content-between align-items-center mb-2">
                  <div class="d-flex align-items-center gap-2">
                    <span class="fw-bold text-dark d-flex align-items-center gap-2">

                      <!-- Icon before the username -->
                      <% if (item.author.staff) { %>
                        <img src="/images/staff.svg" alt="Staff" class="chatImage">
                        <% } else { %>
                          <img src="/images/noStaff.svg" alt="User" title="User" class="chatImage">
                          <% } %>

                            <%= item.author.username %>
                    </span>

                    <!-- Dynamic Badges based on comment type -->
                    <% if (item.commentType==='urgent' ) { %>
                      <span class="badge bg-danger text-dark">Urgent</span>
                      <% } else if (item.commentType==='complaint' ) { %>
                        <span class="badge bg-warning text-dark">Complaint</span>
                        <% } else if (item.commentType==='suggestion' ) { %>
                          <span class="badge bg-success text-dark">Suggestion</span>
                          <% } else { %>
                            <span class="badge bg-info text-dark">Question</span>
                            <% } %>
                  </div>

                  <!-- Delete button for Comment Author -->
                  <% if (user.CPR===item.author.CPR) { %>
                    <form action="/info/<%= foundInfo._id %>/comment/<%= item._id %>?_method=DELETE" method="POST"
                      class="m-0">

                      <button type="submit" class="btn btn-outline-danger btn-sm py-1 px-2 w-auto">
                        Delete
                      </button>

                    </form>
                    <% } %>
                </div>

                <!-- Comment  -->
                <p class="card-text text-secondary mb-0 fs-6">
                  <%= item.text %>
                </p>

              </div>
            </div>

            <% }) %>
        </div>
        <% } else { %>
          <!-- Empty State Card -->
          <div class="card border-0 shadow-sm p-4 text-center bg-light">
            <p class="text-muted mb-0">No comments. Be the first to start the discussion!</p>
          </div>
          <% } %>
    </section>
    <!-- ===============================================================================  -->
    <!-- add comments ===================================================================== -->
    <hr>

    <section class="comment-section p-4 my-4 rounded-3 shadow-sm bg-white border">
      <h2 class="h4 fw-bold mb-3" style="color: #0284C7;">
        Any Comments About This Examination?
      </h2>

      <form action="/info/<%= foundInfo._id %>/comment" method="post">

        <!-- Comment Type Dropdown -->
        <div class="mb-3">
          <label for="commentType" class="form-label fw-semibold text-secondary">
            Select Comment Type
          </label>
          <select name="commentType" id="commentType" class="form-select border-slate">
            <option value="question">Question</option>
            <option value="suggestion">Suggestion</option>
            <option value="complaint">Complaint</option>
            <option value="urgent">Urgent Matter</option>
          </select>
        </div>

        <!-- Comment Textarea -->
        <div class="mb-3">
          <label for="text" class="form-label fw-semibold text-secondary">
            Write a Comment
          </label>
          <textarea name="text" id="text" class="form-control border-slate" rows="4"
            placeholder="Share your feedback, question, ..." required></textarea>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-primary w-auto px-4 py-2 fw-semibold">
          Add Comment
        </button>

      </form>
    </section>
    <br>


  </body>

</html>