<%- include("../partials/nav.ejs") %>

<main class="page-container">
    <section class="auth-card">
        <div class="auth-card-header">
            <h1 class="auth-card-title">Create New Account</h1>
        </div>

        <form class="auth-form" action="/auth/sign-up" method="POST">

            <div class="form-group">
                <label class="form-label" for="username">Username</label>
                <input
                    class="form-input"
                    type="text"
                    name="username"
                    id="username"
                    required
                >

            <div class="form-group">
                <label class="form-label" for="CPR">CPR</label>
                <input
                    class="form-input"
                    type="string"
                    name="CPR"
                    id="CPR"
                    required
                >
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input
                    class="form-input"
                    type="password"
                    name="password"
                    id="password"
                    required
                >
            </div>

            <div class="form-group">
            <label class="form-label" for="confirmPassword"> confirm password</label>
            <input
                    class="form-input"
                    type="password"
                    name="confirmPassword"
                    id="password"
                    required
                >
             </div>

             <div class=''>
                <label for="saff"> are you part of our team</label>

                <input 
                type="checkbox"
                name="staff"
                id="staff"
                >
            </div>
<br>
            <button class="primary-button" type="submit">Sign Up</button>
        </form>

        <p class="auth-card-footer">
            Already have an account?
            <a class="text-link" href="/auth/sign-in">Sign In</a>
        </p>
    </section>
</main>
</body>
</html>
